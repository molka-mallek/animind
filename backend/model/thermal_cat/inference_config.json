{
  "project": "TICD Feline Health Classifier",
  "version": "1.0",
  "created": "2026-05-06T01:17:45.004588",
  "dataset": "Thermal Imaging Cats Dataset (Abdulghafar et al., 2025)",
  "task": "Binary Classification - Healthy vs Sick",
  "clinical_priority": "High Sick-class Recall (minimize false negatives)",
  "preprocessing": {
    "img_size": 224,
    "normalization_mean": [
      0.485,
      0.456,
      0.406
    ],
    "normalization_std": [
      0.229,
      0.224,
      0.225
    ],
    "color_mode": "RGB",
    "note": "Thermal images use RGB color encoding - do NOT convert to grayscale"
  },
  "models": {
    "custom_cnn": {
      "file": "custom_cnn.pth",
      "ensemble_weight": 0.2
    },
    "efficientnet_b3": {
      "file": "efficientnet_b3.pth",
      "ensemble_weight": 0.5,
      "classifier": "Dropout(0.3)->Linear(1536,512)->ReLU->Dropout(0.2)->Linear(512,2)"
    },
    "resnet50": {
      "file": "resnet50.pth",
      "ensemble_weight": 0.3
    }
  },
  "ensemble": {
    "method": "Weighted Soft Voting",
    "weights": {
      "custom_cnn": 0.2,
      "efficientnet_b3": 0.5,
      "resnet50": 0.3
    },
    "threshold": 0.5600000000000003
  },
  "classes": {
    "0": "Healthy",
    "1": "Sick"
  }
}